# Flask
SECRET_KEY=your-very-long-secret-key-here-change-in-production
FLASK_DEBUG=false
PORT=3000

# Database
MYSQL_HOST=127.0.0.1
MYSQL_USER=amsuser
MYSQL_PASSWORD=StrongPassword123
MYSQL_DB=ams

# Optional: for geolocation proximity check (in meters)
COLLEGE_LAT=26.123456
COLLEGE_LNG=91.789012
MAX_DISTANCE_METERS=200

# Public access for phones/devices outside the same Wi-Fi or hotspot.
# Set this after deploying to a public server or configuring router port forwarding.
# Examples:
#   PUBLIC_URL=https://attendance.yourdomain.com
#   PUBLIC_URL=http://203.0.113.10:5000
PUBLIC_URL=https://attendance.tezu.ac.com

# Optional: only set this if your websocket endpoint is on a different origin.
SOCKETIO_URL=

# Debug routes — only accessible when FLASK_DEBUG=true AND this key is sent via X-Debug-Key header
DEBUG_KEY=change-this-to-a-secret-debug-key

# SMTP Configuration (for OTP email verification in forgot password)
# For Gmail: use smtp.gmail.com / 587 / your Gmail / App Password
# Generate App Password: Google Account → Security → 2-Step Verification → App Passwords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=hrishirajbora1111@gmail.com
SMTP_PASSWORD=qfhfjvelaakfwbvz
OTP_EXPIRY_MINUTES=5
